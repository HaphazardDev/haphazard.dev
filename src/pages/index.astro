---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects";

const primaryLinks = [
	{ label: "GitHub", href: "https://github.com/corwinm" },
	{ label: "HaphazardDev", href: "https://github.com/HaphazardDev" },
];
---

<Layout
	title="Haphazard.dev — developer tools by Corwin"
	description="A dev-first home page for Corwin's projects: VS Code extensions, CLIs, tmux integrations, and pi ecosystem experiments."
>
	<a class="skip-link" href="#projects">Skip to projects</a>

	<header id="top" class="site-header" aria-label="Site header">
		<a class="brand" href="/" aria-label="Haphazard.dev home">
			<span class="prompt" aria-hidden="true">~/</span>haphazard.dev
		</a>
		<nav class="top-nav" aria-label="Primary navigation">
			<a href="#projects">projects</a>
			{primaryLinks.map((link) => <a href={link.href}>{link.label}</a>)}
		</nav>
	</header>

	<main>
		<section class="hero" aria-labelledby="hero-title">
			<div class="terminal" aria-label="Project directory terminal preview">
				<div class="terminal-bar">
					<span></span><span></span><span></span>
				</div>
				<div class="terminal-body mono">
					<p><span class="muted">$</span> ls projects/</p>
					{projects.map((project) => <p><a href={`#${project.slug}`}>{project.title}</a><span class="comment"> // {project.category}</span></p>)}
					<p><span class="muted">$</span> open README.md</p>
				</div>
			</div>

			<div class="hero-copy">
				<p class="eyebrow mono">developer tools · workflow experiments · shipped utilities</p>
				<h1 id="hero-title">Tools for people who live in editors, terminals, and Git worktrees.</h1>
				<p class="lede">
					Haphazard.dev is the home base for my projects: pragmatic extensions, CLIs, and integrations
					built to make everyday development workflows faster and more keyboard friendly.
				</p>
				<div class="hero-actions">
					<a class="button primary" href="#projects">Explore projects</a>
					<a class="button" href="https://github.com/corwinm">View GitHub</a>
				</div>
			</div>
		</section>

		<section class="project-index" aria-label="Project quick links">
			{projects.map((project, index) => (
				<a class="index-card" href={`#${project.slug}`}>
					<span class="mono">0{index + 1}</span>
					<strong>{project.title}</strong>
					<small>{project.category}</small>
				</a>
			))}
		</section>

		<section id="projects" class="projects" aria-labelledby="projects-title">
			<div class="section-heading">
				<p class="eyebrow mono">cat ./projects.json</p>
				<h2 id="projects-title">Projects</h2>
			</div>

			<div class="project-list">
				{projects.map((project, index) => (
					<article class="project" id={project.slug}>
						<div class="project-meta mono" aria-hidden="true">project:{String(index + 1).padStart(2, "0")}</div>
						<div class="project-main">
							<p class="category mono">{project.category}</p>
							<h3>{project.title}</h3>
							<p class="description">{project.description}</p>

							<ul class="highlights" aria-label={`${project.title} highlights`}>
								{project.highlights.map((highlight) => <li>{highlight}</li>)}
							</ul>
						</div>

						<aside class="project-side" aria-label={`${project.title} details`}>
							<div>
								<h4 class="mono">stack</h4>
								<div class="tags">
									{project.technologies.map((tech) => <span>{tech}</span>)}
								</div>
							</div>

							<div>
								<h4 class="mono">links</h4>
								<div class="links">
									{project.links.map((link) => (
										<a href={link.href} target="_blank" rel="noreferrer">
											{link.label}<span aria-hidden="true">↗</span>
										</a>
									))}
								</div>
							</div>
						</aside>
					</article>
				))}
			</div>
		</section>

	</main>

	<footer class="site-footer">
		<p class="mono">© {new Date().getFullYear()} Haphazard.dev</p>
		<a href="#top" aria-label="Back to top">back to top ↑</a>
	</footer>
</Layout>

<style>
	.skip-link {
		position: fixed;
		top: 1rem;
		left: 1rem;
		z-index: 10;
		transform: translateY(-200%);
		border: 1px solid var(--accent);
		border-radius: 999px;
		background: var(--bg);
		padding: 0.7rem 1rem;
		color: var(--accent);
		text-decoration: none;
	}

	.skip-link:focus {
		transform: translateY(0);
	}

	.site-header,
	main,
	.site-footer {
		width: min(1120px, calc(100% - 2rem));
		margin-inline: auto;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 5;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 0;
		backdrop-filter: blur(18px);
	}

	.brand,
	.top-nav a,
	.button,
	.index-card,
	.links a,
	.site-footer a {
		text-decoration: none;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.05rem;
		font-weight: 800;
		letter-spacing: -0.03em;
	}

	.prompt,
	.muted,
	.category,
	.eyebrow {
		color: var(--accent);
	}

	.top-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.4rem;
	}

	.top-nav a {
		border: 1px solid transparent;
		border-radius: 999px;
		padding: 0.5rem 0.75rem;
		color: var(--muted);
		font-size: 0.92rem;
	}

	.top-nav a:hover {
		border-color: var(--line);
		color: var(--text);
		background: rgba(101, 255, 159, 0.06);
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
		align-items: center;
		gap: 2rem;
		min-height: 76vh;
		padding: 4rem 0 2rem;
	}

	.terminal,
	.project,
	.index-card {
		border: 1px solid var(--line);
		background: var(--panel);
		box-shadow: var(--shadow);
	}

	.terminal {
		overflow: hidden;
		border-radius: 22px;
		transform: rotate(-1deg);
	}

	.terminal-bar {
		display: flex;
		gap: 0.5rem;
		border-bottom: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.03);
		padding: 0.9rem 1rem;
	}

	.terminal-bar span {
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		background: var(--muted-2);
	}

	.terminal-bar span:first-child {
		background: #ff5f57;
	}

	.terminal-bar span:nth-child(2) {
		background: var(--warning);
	}

	.terminal-bar span:nth-child(3) {
		background: var(--accent);
	}

	.terminal-body {
		padding: 1.25rem;
		font-size: clamp(0.9rem, 1.8vw, 1.02rem);
		line-height: 1.9;
	}

	.terminal-body p {
		margin: 0;
	}

	.terminal-body a {
		color: var(--text);
		text-decoration-color: rgba(101, 255, 159, 0.35);
		text-underline-offset: 0.25em;
	}

	.comment {
		color: var(--muted-2);
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		max-width: 12ch;
		margin-bottom: 1.4rem;
		font-size: clamp(3.2rem, 9vw, 7rem);
		line-height: 0.88;
		letter-spacing: -0.08em;
	}

	.lede {
		max-width: 62ch;
		color: var(--muted);
		font-size: clamp(1.05rem, 2vw, 1.25rem);
		line-height: 1.7;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 2rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--line-strong);
		border-radius: 999px;
		padding: 0.8rem 1.05rem;
		color: var(--text);
		font-weight: 700;
	}

	.button.primary {
		border-color: transparent;
		background: var(--accent);
		color: #04210e;
	}

	.button:hover,
	.index-card:hover,
	.links a:hover {
		transform: translateY(-1px);
	}

	.project-index {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.8rem;
		margin: 1rem 0 6rem;
	}

	.index-card {
		display: grid;
		gap: 0.35rem;
		border-radius: 18px;
		padding: 1rem;
		transition: transform 180ms ease, border-color 180ms ease;
	}

	.index-card:hover {
		border-color: var(--line-strong);
	}

	.index-card span,
	.index-card small {
		color: var(--muted-2);
	}

	.projects {
		padding: 2rem 0 6rem;
	}

	.section-heading {
		display: grid;
		grid-template-columns: 0.85fr 1.15fr;
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1.5rem;
	}

	.section-heading h2 {
		margin-bottom: 0;
		font-size: clamp(2.2rem, 5vw, 4rem);
		line-height: 0.95;
		letter-spacing: -0.06em;
	}


	.project-list {
		display: grid;
		gap: 1rem;
	}

	.project {
		display: grid;
		grid-template-columns: 8rem minmax(0, 1fr) 18rem;
		gap: 1.4rem;
		scroll-margin-top: 6rem;
		border-radius: 26px;
		padding: 1.2rem;
	}

	.project-meta {
		color: var(--muted-2);
		writing-mode: vertical-rl;
	}

	.project h3 {
		margin-bottom: 0.8rem;
		font-size: clamp(2rem, 4vw, 3.5rem);
		line-height: 0.95;
		letter-spacing: -0.05em;
	}

	.description,
	.highlights {
		color: var(--muted);
		line-height: 1.7;
	}

	.highlights {
		padding-left: 1.2rem;
	}

	.highlights li + li {
		margin-top: 0.55rem;
	}

	.project-side {
		display: flex;
		flex-direction: column;
		gap: 1.3rem;
		border-left: 1px solid var(--line);
		padding-left: 1.3rem;
	}

	h4 {
		margin: 0 0 0.8rem;
		color: var(--muted-2);
		font-size: 0.76rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.tags,
	.links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tags span,
	.links a,
	code {
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(101, 255, 159, 0.06);
	}

	.tags span,
	.links a {
		padding: 0.45rem 0.65rem;
		font-size: 0.85rem;
	}

	.tags span {
		color: var(--muted);
	}

	.links a {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--text);
		transition: transform 180ms ease, border-color 180ms ease;
	}

	.links a:hover {
		border-color: var(--accent);
	}


	code {
		padding: 0.1rem 0.35rem;
		color: var(--accent);
		font-size: 0.9em;
	}

	.site-footer {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		border-top: 1px solid var(--line);
		padding: 2rem 0 3rem;
		color: var(--muted-2);
	}

	.site-footer p {
		margin: 0;
	}

	.site-footer a {
		color: var(--muted);
	}

	@media (max-width: 900px) {
		.site-header,
		.hero,
		.section-heading,
		.project {
			grid-template-columns: 1fr;
		}

		.site-header {
			display: grid;
		}

		.top-nav {
			justify-content: flex-start;
		}

		.hero {
			min-height: auto;
			padding-top: 2rem;
		}

		.terminal {
			order: 2;
			transform: none;
		}

		.project-index {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			margin-bottom: 4rem;
		}

		.project-meta {
			writing-mode: initial;
		}

		.project-side {
			border-top: 1px solid var(--line);
			border-left: 0;
			padding-top: 1.2rem;
			padding-left: 0;
		}
	}

	@media (max-width: 560px) {
		.site-header,
		main,
		.site-footer {
			width: min(100% - 1rem, 1120px);
		}

		h1 {
			font-size: clamp(2.8rem, 18vw, 4.8rem);
		}

		.project-index {
			grid-template-columns: 1fr;
		}

		.project {
			border-radius: 20px;
			padding: 1rem;
		}

		.site-footer {
			flex-direction: column;
		}
	}
</style>
