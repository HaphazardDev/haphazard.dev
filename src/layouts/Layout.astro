---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Haphazard.dev — developer tools by Corwin",
	description = "A home base for Corwin's developer tools, extensions, CLIs, and workflow experiments.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#07100c" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #07100c;
		--bg-soft: #0c1712;
		--panel: rgba(9, 22, 16, 0.84);
		--panel-strong: rgba(14, 32, 24, 0.96);
		--line: rgba(128, 255, 177, 0.18);
		--line-strong: rgba(128, 255, 177, 0.34);
		--text: #e9fff2;
		--muted: #91b79f;
		--muted-2: #6d917a;
		--accent: #65ff9f;
		--accent-2: #7dd3fc;
		--warning: #ffd166;
		--shadow: 0 24px 70px rgba(0, 0, 0, 0.42);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: var(--bg);
		color: var(--text);
	}

	* {
		box-sizing: border-box;
	}

	html {
		margin: 0;
		min-height: 100%;
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-height: 100%;
		background:
			radial-gradient(circle at top left, rgba(101, 255, 159, 0.16), transparent 28rem),
			radial-gradient(circle at 80% 10%, rgba(125, 211, 252, 0.11), transparent 26rem),
			linear-gradient(180deg, #07100c 0%, #08130f 52%, #050907 100%);
		color: var(--text);
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		content: "";
		background-image:
			linear-gradient(rgba(128, 255, 177, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(128, 255, 177, 0.035) 1px, transparent 1px);
		background-size: 36px 36px;
		mask-image: linear-gradient(to bottom, black, transparent 85%);
	}

	a {
		color: inherit;
	}

	::selection {
		background: rgba(101, 255, 159, 0.28);
		color: var(--text);
	}

	:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 4px;
	}

	code,
	kbd,
	pre,
	.mono {
		font-family:
			"SFMono-Regular", "Cascadia Code", "Roboto Mono", Consolas, "Liberation Mono", monospace;
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			scroll-behavior: auto !important;
			transition-duration: 0.01ms !important;
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
		}
	}
</style>
